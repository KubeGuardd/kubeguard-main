# --- Azure Entra ID ---
AZURE_TENANT_ID=your-entra-tenant-id
AZURE_CLIENT_ID=your-app-registration-client-id

# --- Security ---
INTERNAL_SECRET=replace-with-64-char-random-string
ENCRYPTION_KEY=exactly-32-characters-here-1234!

# --- Frontend ---
VITE_AZURE_CLIENT_ID=your-app-registration-client-id
VITE_AZURE_TENANT_ID=your-tenant-id
VITE_AZURE_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_API_BASE_URL=http://localhost:3000

# --- CORS ---
FRONTEND_URL=http://localhost:5173

# --- Database ---
MONGODB_URI=mongodb+srv://user:pass@your-cosmos.mongo.cosmos.azure.com/kubeguard?tls=true&retrywrites=false

# --- Analysis Service ---
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=your-ai-api-key
AI_MODEL=gpt-4o-mini
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=kubeguard-reports
SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=yourkey
SERVICE_BUS_QUEUE=report-ready
ADMIN_EMAILS=admin1@example.com,admin2@example.com

# --- GitHub ---
GITHUB_TOKEN=ghp_your_github_personal_access_token
GATEWAY_PUBLIC_URL=https://your-gateway-domain.azurewebsites.net

# --- Internal Service URLs ---
PROJECT_SERVICE_URL=http://localhost:3001
ANALYSIS_SERVICE_URL=http://localhost:3003
WATCHER_SERVICE_URL=http://localhost:3002
